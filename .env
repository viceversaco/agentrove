POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379

DOCKER_IMAGE=ghcr.io/mng-dev-ai/agentrove-sandbox:latest

BACKEND_PORT=8080
VNC_PORT=5900
VNC_WS_PORT=6080
OPENVSCODE_PORT=8765

DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0
SECRET_KEY=agentrove_default_secret_key_for_development_only
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
HOST_STORAGE_PATH=${PWD}/storage
HOST_PERMISSION_API_URL=http://api:8080
DOCKER_PERMISSION_API_URL=http://agentrove-api-web:8080

FRONTEND_PORT=3000
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/api/v1/ws
